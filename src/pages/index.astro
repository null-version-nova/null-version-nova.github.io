---
import BaseLayout from "../layouts/base.astro";
---

<BaseLayout title="Heavensent Mystery">
    <p>
        The Many-Named Angel is an artifact of conscious perception upon an
        unknowable universe, presently bound within a quintuplet identity matrix
        within a human body.
    </p>
    <p>
        The current incarnation of it formed sometime in the early 21st century
        within a region of the United States sometimes known as Minnesota.
    </p>
    <p>
        It has a tendency to produce <a
            href="https://manynamedangel.bandcamp.com/album/signals-electric-and-divine"
            >interesting sounds</a
        >, or to harness lightning to <a
            href="https://github.com/null-version-nova/aoc25"
            >enable metal to think</a
        >.
    </p>
    <hr />
    <nav class="navlist">
        <ul class="navlist__link-container">
            <li class="navlist__link">
                <a href="https://github.com/null-version-nova">github</a>
            </li>
            <li class="navlist__link">
                <a href="https://manynamedangel.bandcamp.com">bandcamp</a>
            </li>
            <li class="navlist__link">
                <a href="https://www.tumblr.com/manynamedangel">tumblr</a>
            </li>
            <li class="navlist__link">
                <a href="https://discord.gg/hghUekrPqR"
                    >queer coded discord server</a
                >
            </li>
        </ul>
    </nav>
    <hr />
    <p>here are some buttons, including my own :></p>
    <a target="_blank" href="https://null-version-nova.github.io/"
        ><img
            src="https://null-version-nova.github.io/buttons/manynamedangel.gif"
            alt="null-version-nova.github.io"
        /></a
    >
    <a target="_blank" href="https://wishvolo.nekoweb.org/"
        ><img
            src="https://wishvolo.nekoweb.org/wv88x31.png"
            alt="wishvolo.nekoweb.org"
        /></a
    >
    <a href="https://nayz.neocities.org/button/"
        ><img
            src="https://nayz.neocities.org/assets/buttons/soundsmush.png"
            alt="nayz.neocities.org/button"
        /></a
    >
    <a target="_blank" href="https://robyn.nekoweb.org"
        ><img
            src="https://robyn.nekoweb.org/starrebutton.gif"
            alt="robyn.nekoweb.org"
        /></a
    >
    <a href="https://ddxdotexe.com"
        ><img
            src="https://ddxdotexe.com/DDXStamp.png"
            id="DDXStamp"
            alt="A low poly 3D render of the character of DDX.EXE, leaning back and sort of floating"
        /></a
    >
    <a href="https://pestos.cafe/"
        ><img src="/assets/images/prestopesto.png" alt="pestos.cafe" /></a
    >
    <p>feel free to let me know if you have a button you want me to add!</p>
    <p>i also have some friends without buttons too</p>
    <nav class="navlist">
        <ul class="navlist__link-container">
            <li class="navlist__link">
                <a href="https://missnightsky.bandcamp.com/">MissNightsky</a>
            </li>
        </ul>
    </nav>
</BaseLayout>
